generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model otps {
  roll      String  @id @db.VarChar(50)
  otp       String? @db.VarChar(10)
  email     String? @db.VarChar(150)
  timestamp BigInt?
}

model results {
  roll                  String  @id @db.VarChar(50)
  name                  String? @db.VarChar(100)
  branch                String? @db.VarChar(100)
  marks                 Int?    @default(0)
  attempts              Int?    @default(0)
  status                String? @default("Not Started") @db.VarChar(50)
  timestamp             String? @db.VarChar(100)
  question_details      Json?
  time_taken            Int?    @default(0)
  last_active_str       String? @db.VarChar(100)
  last_sync_str         String? @db.VarChar(100)
  student_id            String? @db.VarChar(100)
  exam_id               String? @db.VarChar(100)
  percentage            Float?
  correct_count         Int?    @default(0)
  wrong_count           Int?    @default(0)
  result_classification String? @db.VarChar(50)
  tab_warnings          Int?    @default(0)
  exam_start_time       String? @db.VarChar(100)
  exam_end_time         String? @db.VarChar(100)
  submission_type       String? @db.VarChar(50)
  department            String? @db.VarChar(100)
  section               String? @db.VarChar(50)
  semester              String? @db.VarChar(50)
  academic_year         String? @db.VarChar(50)
  mobile_number         String? @db.VarChar(50)
  email                 String? @db.VarChar(150)
  exam_permission       String? @default("Allowed") @db.VarChar(50)
  login_time            String? @db.VarChar(100)
  login_device          String? @db.VarChar(100)
  login_browser         String? @db.VarChar(255)
  login_ip              String? @db.VarChar(100)
  current_question      Int?    @default(0)
  current_activity      String? @db.VarChar(255)
  online_status         String? @default("Offline") @db.VarChar(50)
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now()) @updatedAt
}

model activity_logs {
  id         Int      @id @default(autoincrement())
  roll       String   @db.VarChar(50)
  event_type String   @db.VarChar(50)
  details    String?  @db.Text
  timestamp  DateTime @default(now())

  @@index([roll])
  @@index([timestamp])
}


